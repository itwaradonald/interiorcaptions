background-position:center;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
color:white;
padding:20px;
}

.hero h1{
font-size:3.5rem;
margin:0;
}

.hero p{
font-size:1.2rem;
}

.btn{
display:inline-block;
margin-top:20px;
padding:12px 25px;
background:var(--gold);
color:white;
text-decoration:none;
border-radius:5px;
font-weight:bold;
}

/* SECTIONS */
section{
padding:70px 10%;
}

h2{
color:var(--navy);
font-family:Montserrat;
margin-bottom:20px;
}

/* GRID */
.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
}

.card{
background:white;
padding:20px;
border-radius:10px;
box-shadow:0 5px 15px rgba(0,0,0,0.1);
}

/* CONTACT */
.contact{
background:var(--navy);
color:white;
}

.contact h2{
color:white;
}

/* FOOTER */
footer{
text-align:center;
padding:20px;
background:#0a1a2b;
color:white;
}

/* WHATSAPP */
.whatsapp{
position:fixed;
bottom:20px;
right:20px;
background:#25D366;
color:white;
padding:15px;
border-radius:50%;
font-size:22px;
text-decoration:none;
}

